# Flask Configuration
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# GPU Configuration
USE_GPU=true
CUDA_VISIBLE_DEVICES=0

# Model Configuration
MODEL_CACHE_DIR=./weights
HUGGINGFACE_CACHE_DIR=./weights/huggingface

# Hugging Face Hub (required for gated/private models like StabilityAI)
# 1) Create a token at https://huggingface.co/settings/tokens
# 2) Accept the model license on the model page (if prompted)
HF_TOKEN=

# Stable Diffusion Inpainting model repo id
# Default: stable-diffusion-v1-5/stable-diffusion-inpainting (public)
# If you want to use a gated model (e.g. StabilityAI), you must set HF_TOKEN and accept the license.
SD_INPAINTING_MODEL=stable-diffusion-v1-5/stable-diffusion-inpainting

# Upload Configuration
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif

# API Configuration
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
